# AI Gateway Environment Variables
# Copy this file to .env and fill in your values

# MongoDB (leave blank to use in-memory DB for local dev)
MONGO_URI=

# JWT
JWT_SECRET=your_jwt_secret_here

# AI Gateway — fill these in to enable AI scoring and chat
AI_GATEWAY_URL=https://your-ai-endpoint.com/api
AI_GATEWAY_KEY=your_api_key_here

# Server
PORT=5001

# Twilio (For sending real crisis text messages)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# Backend Api's
AI_URL_START=
AI_URL_ANSWER=
CALL_API_URL=
SMS_API_URL=